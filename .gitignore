.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Large MoneyPuck CSVs (55 MB + 76 MB) — exceed Vercel hobby function bundle limit.
# goalies.csv (1.5 MB) and teams.csv (1.6 MB) are committed and work fine.
# For skaters + lines historical context, connect Supabase (see data/README.md).
data/skaters.csv
data/lines.csv
# lines_slim.csv is intentionally committed — filtered, Vercel-safe version
!data/lines_slim.csv
